{
  "manifest_version": 3,
  "name": "Watch Party — Stream Catcher",
  "version": "2.1",
  "description": "Перехватывает видеопотоки и добавляет Watch Party на Кинопоиск",
  "permissions": [
    "webRequest",
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.kinopoisk.ru/film/*",
        "https://www.kinopoisk.ru/series/*",
        "https://www.kinopoisk.ru/show/*",
        "https://kinopoisk.ru/film/*",
        "https://kinopoisk.ru/series/*",
        "https://kinopoisk.ru/show/*"
      ],
      "js": ["kinopoisk.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Watch Party"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
